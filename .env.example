APP_ENV=development
SESSION_COOKIE_SECURE=false
HTTP_ADDR=:8080
CORS_ALLOWED_ORIGINS=
DATABASE_URL=postgres://opportunity:opportunity@localhost:5432/opportunity?sslmode=disable
REDIS_URL=redis://localhost:6379/0
OUTBOX_MAX_LAG_SECONDS=300
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=opportunity
S3_SECRET_KEY=change-me-in-production
S3_BUCKET=opportunity-artifacts
LOG_LEVEL=info
NEXT_PUBLIC_CORE_API_URL=http://127.0.0.1:8080
NEXT_PUBLIC_TENANT_ID=00000000-0000-4000-8000-000000000001
NEXT_PUBLIC_ACTOR_ID=operator-console
PRODUCTION_CHECK_TENANT_ID=00000000-0000-4000-8000-000000000001
# Adapter secrets are injected by the deployment secret manager, for example:
# OPPORTUNITY_ADAPTER_SECRET_PRIMARY=<managed-secret>
